# CONFIGURACIÓN DEL SERVIDOR
NODE_ENV=development
PORT=5000

# BASE DE DATOS MYSQL (XAMPP)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=nexuscreative_medical

# JWT
JWT_SECRET=nexuscreative_super_secret_key_2026_change_this_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=nexuscreative_refresh_secret_key_2026
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# ARCHIVOS
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# EMAIL (Opcional - para notificaciones)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@nexuscreative.com

# WHATSAPP (Opcional - para recordatorios)
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER=

# TIMEZONE
TZ=America/Lima
